{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Wolfram Language (Markdown)",
  "scopeName": "markdown.wolfram.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    {
      "include": "#wolfram-block"
    }
  ],
  "repository": {
    "wolfram-block": {
      "name": "markup.fenced_code.block.markdown",
      "contentName": "meta.embedded.block.wolfram",
      "begin": "(^|\\G)(\\s*)(```+|~~~+)\\s*(?i:(wolfram|wl|mathematica))\\s*$",
      "end": "(^|\\G)(\\2)(\\3)\\s*$",
      "beginCaptures": {
        "3": {
          "name": "punctuation.definition.fenced.markdown"
        },
        "4": {
          "name": "fenced_code.block.language.markdown"
        }
      },
      "endCaptures": {
        "3": {
          "name": "punctuation.definition.fenced.markdown"
        }
      },
      "patterns": [
        {
          "include": "source.wolfram"
        }
      ]
    }
  }
}
